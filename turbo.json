{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"],
      "env": [
        "INTERNAL_API_URL",
        "NEXT_PUBLIC_USE_SAME_ORIGIN_API",
        "NEXT_PUBLIC_REALTIME_URL",
        "NEXT_PUBLIC_REALTIME_PATH",
        "NEXT_PUBLIC_LISTING_IMAGE_CDN_URL",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_SENTRY_DSN_WEB",
        "SENTRY_DSN_WEB",
        "VERCEL_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "passThroughEnv": [
        "CI",
        "NODE_ENV",
        "DATABASE_URL",
        "DIRECT_URL",
        "TEST_DATABASE_URL",
        "TEST_DIRECT_URL",
        "REDIS_URL",
        "JWT_SECRET",
        "JWT_ACCESS_TOKEN_TTL",
        "JWT_REFRESH_TOKEN_TTL",
        "JWT_REALTIME_TOKEN_TTL",
        "TWILIO_ACCOUNT_SID",
        "TWILIO_AUTH_TOKEN",
        "TWILIO_VERIFY_SERVICE_SID"
      ]
    }
  }
}
