{
  "name": "@sellr/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "algolia:configure": "tsx src/scripts/configureAlgolia.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.5.1",
    "@logtail/pino": "^0.5.0",
    "@prisma/adapter-pg": "^7",
    "@prisma/client": "^7.7.0",
    "@sellr/shared": "workspace:*",
    "@sentry/node": "^9.0.0",
    "algoliasearch": "^5.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.5.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^6.0.0",
    "ioredis": "^5.4.0",
    "langfuse": "^3.38.20",
    "openai": "^5.0.0",
    "openapi-types": "^12.1.3",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "posthog-node": "^4.0.0",
    "socket.io": "^4.8.0",
    "twilio": "^5.0.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@sellr/tsconfig": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "prisma": "^7.7.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  }
}
