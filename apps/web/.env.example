# Copy to .env.local:   cp .env.example .env.local
# Or: pnpm env:web  (from repo root)
#
# Required for httpOnly auth cookies: browser must call same-origin /api/v1 (Next
# rewrites to Fastify). Do not set NEXT_PUBLIC_API_URL here — that would bypass
# the rewrite and break cookie sessions.

# Where Next.js rewrites /api/v1/* (server-side). Default matches local API.
INTERNAL_API_URL=http://127.0.0.1:3001

# Enable same-origin API + X-Sellr-Client: web in @sellr/api-client
NEXT_PUBLIC_USE_SAME_ORIGIN_API=1

# Listing image CDN host allow-listed by Next/Image in next.config.ts.
NEXT_PUBLIC_LISTING_IMAGE_CDN_URL=https://cdn.sellr-ai.com

# Optional: canonical site URL used for Open Graph / Twitter card image
# resolution. Falls back to VERCEL_URL on Vercel, or http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://sellr.example

# Optional
# NEXT_PUBLIC_SENTRY_DSN_WEB=https://xxx@xxx.ingest.sentry.io/xxx
